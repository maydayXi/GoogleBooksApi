@using GoogleBookApi.Controllers
@using GoogleBookApi.Helper

@{
    string homeController = WebHelper.GetControllerName<HomeController>();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GoogleBookApi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GoogleBookApi.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/sweetalert2/dist/css/sweetalert2.min.css" asp-append-version="true" />
    @RenderSection("Headers", false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bolder" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-book"></i>
                    GoogleBooksApi
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center text-start">
                        <li class="nav-item d-flex align-items-center">
                            <i class="bi bi-house me-2 d-inline-block d-sm-none"></i>
                            <a class="nav-link text-dark" asp-area="" asp-controller="@homeController" asp-action="@nameof(HomeController.Index)">
                                @homeController
                            </a>
                        </li>
                        <li class="nav-item d-flex align-items-center">
                            <i class="bi bi-info-circle d-inline-block d-sm-none me-2"></i>
                            <a class="nav-link text-dark" asp-area="" asp-controller="@homeController" asp-action="@nameof(HomeController.Guideline)">
                                @nameof(HomeController.Guideline)
                            </a>
                        </li>
                        <li class="nav-item d-flex align-items-center">
                            <i class="bi bi-search d-inline-block d-sm-none me-2"></i>
                            <a class="nav-link text-dark" asp-area="" asp-controller="@homeController" asp-action="@nameof(HomeController.BookSearch)">
                                @nameof(HomeController.BookSearch)
                            </a>
                        </li>
                        <li class="nav-link">
                            @* <i class="bi bi-git"></i> *@
                            <a class="nav-link text-dark" asp-area="" asp-controller="@homeController" asp-action="@nameof(HomeController.Version)">
                                @nameof(HomeController.Version)
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <partial name="_Loader" />
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!--
    <footer class="border-top footer text-muted position-fixed">
        <div class="container">
            &copy; 2026 - GoogleBookApi - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
